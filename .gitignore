# ── Dependencies ──────────────────────────────────────────────────
node_modules/

# ── Recordings & user data (generated at runtime) ─────────────────
data/

# ── Recording files that may end up at root (drafts, tests) ───────
*.webm
*.wav
*.m4a
*.mp3
*.ogg

# ── Generated by install.sh (contains secrets) ────────────────────
.env
server/src/config.json

# ── Launcher runtime state ────────────────────────────────────────
launcher/.launched
launcher/.launcher.pid

# ── macOS ─────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── Logs ──────────────────────────────────────────────────────────
*.log
